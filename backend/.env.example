# Application
APP_ENV=development
APP_DEBUG=1
APP_URL=http://127.0.0.1:8080

# Allowed browser origin for CORS (Vite dev server)
CORS_ORIGIN=http://127.0.0.1:5173

# Database (used from Phase 1 onward; single schema file + one DSN)
DB_DRIVER=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=locally
DB_USER=locally
DB_PASSWORD=secret

# Session (Phase 2+)
SESSION_NAME=LOCALLY_SESSION
# Set to 1 behind HTTPS so the session cookie is not sent over plain HTTP
SESSION_SECURE=0

# Secrets (Phase 2+)
APP_KEY=change-me-to-a-long-random-string

# Phase 9 hardening
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_AUTH_LOGIN_PER_WINDOW=12
RATE_LIMIT_AUTH_REGISTER_PER_WINDOW=8
RATE_LIMIT_ANALYTICS_PER_WINDOW=180
RATE_LIMIT_ORDERS_CREATE_PER_WINDOW=20
RATE_LIMIT_CONFIRMER_DECISION_PER_WINDOW=60
RATE_LIMIT_UPLOADS_PER_WINDOW=20
# API CSP response header (backend/public serves API JSON; frontend build CSP is set in Vite build config)
CONTENT_SECURITY_POLICY=default-src 'none'; frame-ancestors 'none'
# Optional upload scanner command. Examples:
#   Linux clamav: clamscan --no-summary {file}
#   Windows Defender CLI: "C:\\Program Files\\Windows Defender\\MpCmdRun.exe" -Scan -ScanType 3 -File {file}
UPLOAD_SCAN_COMMAND=
UPLOAD_SCAN_REQUIRED=0
